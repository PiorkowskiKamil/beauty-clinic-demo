{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": { "contentSize": "46rem", "wideSize": "75rem" },
		"color": {
			"defaultPalette": true,
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "Base" },
				{ "slug": "contrast", "color": "#221f1a", "name": "Contrast" },
				{ "slug": "primary", "color": "#daa520", "name": "Złoto (primary)" },
				{ "slug": "primary-dark", "color": "#8c6d12", "name": "Złoto ciemne" },
				{ "slug": "secondary", "color": "#6f9c8b", "name": "Mięta (secondary)" },
				{ "slug": "secondary-soft", "color": "#eafaf5", "name": "Mięta jasna" },
				{ "slug": "cream", "color": "#faf7f0", "name": "Krem" },
				{ "slug": "sand", "color": "#e8e4dc", "name": "Piasek" },
				{ "slug": "muted", "color": "#635f57", "name": "Stonowany" }
			]
		},
		"typography": {
			"fontFamilies": [
				{ "fontFamily": "'Lato', -apple-system, 'Segoe UI', sans-serif", "slug": "body", "name": "Lato" },
				{ "fontFamily": "'Playfair Display', Georgia, serif", "slug": "heading", "name": "Playfair Display" }
			],
			"fontSizes": [
				{ "slug": "x-small", "size": "0.8125rem", "name": "X-Small" },
				{ "slug": "small", "size": "0.9375rem", "name": "Small" },
				{ "slug": "normal", "size": "16px", "name": "Normal" },
				{ "slug": "medium", "size": "1.0625rem", "name": "Medium" },
				{ "slug": "large", "size": "clamp(1.125rem, 1.125rem + ((1vw - 0.2rem) * 0.227), 1.25rem)", "name": "Large" },
				{ "slug": "x-large", "size": "clamp(1.5rem, 1.5rem + ((1vw - 0.2rem) * 0.455), 1.75rem)", "name": "X-Large" },
				{ "slug": "xx-large", "size": "clamp(2rem, 2rem + ((1vw - 0.2rem) * 1.818), 3rem)", "name": "XX-Large" },
				{ "slug": "huge", "size": "clamp(2.5rem, 2.5rem + ((1vw - 0.2rem) * 2.273), 3.75rem)", "name": "Huge" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem", "name": "1" },
				{ "slug": "20", "size": "0.75rem", "name": "2" },
				{ "slug": "30", "size": "1.25rem", "name": "3" },
				{ "slug": "40", "size": "2rem", "name": "4" },
				{ "slug": "50", "size": "clamp(2.75rem, 6vw, 4.5rem)", "name": "5" },
				{ "slug": "60", "size": "clamp(4.5rem, 9vw, 7rem)", "name": "6" },
				{ "slug": "70", "size": "3.38rem", "name": "7" },
				{ "slug": "80", "size": "5.06rem", "name": "8" }
			]
		}
	},
	"styles": {
		"color": { "background": "var(--wp--preset--color--base)", "text": "var(--wp--preset--color--contrast)" },
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": { "top": "0px", "right": "clamp(1.25rem, 4vw, 2.5rem)", "bottom": "0px", "left": "clamp(1.25rem, 4vw, 2.5rem)" }
		},
		"elements": {
			"heading": { "color": { "text": "var(--wp--preset--color--contrast)" }, "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontWeight": "600", "lineHeight": "1.18" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--primary-dark)" },
				"typography": { "textDecoration": "none" },
				":hover": { "color": { "text": "var(--wp--preset--color--contrast)" }, "typography": { "textDecoration": "none" } }
			},
			"button": {
				"color": { "background": "var(--wp--preset--color--primary)", "text": "var(--wp--preset--color--contrast)" },
				"border": { "radius": "999px", "width": "0px" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"letterSpacing": "0.02em",
					"textDecoration": "none"
				},
				"spacing": { "padding": { "top": "0.85rem", "right": "2rem", "bottom": "0.85rem", "left": "2rem" } },
				":hover": { "color": { "background": "var(--wp--preset--color--contrast)", "text": "var(--wp--preset--color--base)" } }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Nagłówek", "area": "header" },
		{ "name": "footer", "title": "Stopka", "area": "footer" }
	]
}
