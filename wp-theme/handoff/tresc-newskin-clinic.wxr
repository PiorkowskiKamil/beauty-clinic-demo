	<item>
		<title>Krem na noc</title>
		<link>https://newskin.local/produkt-krem-na-noc/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Krem odżywczy na noc</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:columns {"align":"wide"} -->
<div class="wp-block-columns alignwide">
<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded bc-product-photo"} -->
<figure class="wp-block-image size-full bc-rounded bc-product-photo"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-2.jpg" alt="Krem odżywczy na noc"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">129 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph">Bogaty krem na noc z ceramidami, który wspiera regenerację skóry podczas snu i odbudowę bariery hydrolipidowej. Cera sucha i zmęczona odzyskuje komfort, miękkość i nawilżenie.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color wp-block-paragraph">Nakładaj wieczorem na oczyszczoną twarz i szyję jako ostatni krok pielęgnacji. Polecany szczególnie w sezonie grzewczym i dla skóry odwodnionej.</p>
<!-- /wp:paragraph -->

<!-- wp:buttons -->
<div class="wp-block-buttons">
<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/kontakt/">Zapytaj o produkt</a></div>
<!-- /wp:button -->

<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/produkty/">Wróć do produktów</a></div>
<!-- /wp:button -->
</div>
<!-- /wp:buttons -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->
]]></content:encoded>
