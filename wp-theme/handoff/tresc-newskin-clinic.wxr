	<item>
		<title>Kontakt</title>
		<link>https://newskin.local/kontakt/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Kontakt</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained","contentSize":"75rem"}} -->
<div class="wp-block-group alignfull" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:columns {"align":"wide","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"4rem"}}}} -->
<div class="wp-block-columns alignwide">
<!-- wp:column {"width":"40%"} -->
<div class="wp-block-column" style="flex-basis:40%">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Dane kontaktowe</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 class="has-text-align-center wp-block-heading has-x-large-font-size">Zapraszamy do salonu</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph"><strong>NEW SKIN clinic</strong><br>ul. Przykładowa 1<br>00-001 Warszawa</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph">Telefon: <a href="tel:+48123456789">+48 123 456 789</a><br>E-mail: <a href="mailto:kontakt@example.com">kontakt@example.com</a></p>
<!-- /wp:paragraph -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-large-font-size">Godziny otwarcia</h3>
<!-- /wp:heading -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph">Poniedziałek–piątek: 9:00–20:00<br>Sobota: 9:00–14:00<br>Niedziela: nieczynne</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Wizyty umawiamy telefonicznie lub przez formularz. Na wiadomości odpowiadamy w&nbsp;dni robocze do 24 godzin.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->

<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Formularz</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 class="has-text-align-center wp-block-heading has-x-large-font-size">Napisz do nas</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:html -->
<div class="wpcf7 no-js" id="wpcf7-f4-p10-o1" lang="pl-PL" dir="ltr" data-wpcf7-id="4">
<div class="screen-reader-response"><p role="status" aria-live="polite" aria-atomic="true"></p> <ul></ul></div>
<form action="index.html#wpcf7-f4-p10-o1" method="post" class="wpcf7-form init" aria-label="Formularz kontaktowy" novalidate="novalidate" data-status="init">
<fieldset class="hidden-fields-container"><input type="hidden" name="_wpcf7" value="4"><input type="hidden" name="_wpcf7_version" value="6.1.6"><input type="hidden" name="_wpcf7_locale" value="pl_PL"><input type="hidden" name="_wpcf7_unit_tag" value="wpcf7-f4-p10-o1"><input type="hidden" name="_wpcf7_container_post" value="10"><input type="hidden" name="_wpcf7_posted_data_hash" value="">
</fieldset>
<p><label> Imię i&nbsp;nazwisko<br>
<span class="wpcf7-form-control-wrap" data-name="your-name"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text wpcf7-validates-as-required" autocomplete="name" aria-required="true" aria-invalid="false" value="" type="text" name="your-name"></span> </label>
</p>
<p><label> Adres e-mail<br>
<span class="wpcf7-form-control-wrap" data-name="your-email"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email" autocomplete="email" aria-required="true" aria-invalid="false" value="" type="email" name="your-email"></span> </label>
</p>
<p><label> Telefon (opcjonalnie)<br>
<span class="wpcf7-form-control-wrap" data-name="your-phone"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-tel wpcf7-text wpcf7-validates-as-tel" autocomplete="tel" aria-invalid="false" value="" type="tel" name="your-phone"></span> </label>
</p>
<p><label> Wiadomość<br>
<span class="wpcf7-form-control-wrap" data-name="your-message"><textarea cols="40" rows="10" maxlength="2000" class="wpcf7-form-control wpcf7-textarea wpcf7-validates-as-required" aria-required="true" aria-invalid="false" name="your-message"></textarea></span> </label>
</p>
<p><span class="wpcf7-form-control-wrap" data-name="rodo-zgoda"><span class="wpcf7-form-control wpcf7-acceptance"><span class="wpcf7-list-item"><label><input type="checkbox" name="rodo-zgoda" value="1" aria-invalid="false"><span class="wpcf7-list-item-label">Wyrażam zgodę na przetwarzanie moich danych osobowych w&nbsp;celu odpowiedzi na zapytanie.</span></label></span></span></span>
</p>
<p><input class="wpcf7-form-control wpcf7-submit has-spinner" type="submit" value="Wyślij wiadomość">
</p><div class="wpcf7-response-output" aria-hidden="true"></div>
</form>
</div>
<!-- /wp:html -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"3rem"} -->
<div style="height:3rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:group {"align":"wide","className":"bc-map","layout":{"type":"constrained"}} -->
<div id="mapa" class="wp-block-group alignwide bc-map">
<!-- wp:html -->
<iframe src="https://maps.google.com/maps?q=Warszawa&amp;z=13&amp;output=embed" width="600" height="420" title="Mapa dojazdu do salonu NEW SKIN clinic (adres przykładowy)" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
<!-- /wp:html -->
</div>
<!-- /wp:group -->

<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color has-x-small-font-size wp-block-paragraph">Mapa poglądowa — pinezkę ustawimy na docelowy adres salonu.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->
]]></content:encoded>
