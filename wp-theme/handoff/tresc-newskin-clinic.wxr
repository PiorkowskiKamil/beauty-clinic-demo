		<wp:status><![CDATA[publish]]></wp:status>
		<wp:post_type><![CDATA[page]]></wp:post_type>
		<wp:post_parent>0</wp:post_parent>
		<wp:menu_order>0</wp:menu_order>
		<wp:comment_status><![CDATA[closed]]></wp:comment_status>
		<wp:ping_status><![CDATA[closed]]></wp:ping_status>
	</item>
	<item>
		<title>Serum z witaminą C</title>
		<link>https://newskin.local/produkt-serum-witamina-c/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Serum rewitalizujące z witaminą C</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:columns {"align":"wide"} -->
<div class="wp-block-columns alignwide">
<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded bc-product-photo"} -->
<figure class="wp-block-image size-full bc-rounded bc-product-photo"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-1.jpg" alt="Serum rewitalizujące z witaminą C"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">149 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph">Rozświetlające serum ze stabilizowaną witaminą C, które wyrównuje koloryt i przywraca skórze zdrowy blask. Lekka formuła szybko się wchłania, wspierając cerę zmęczoną i pozbawioną energii.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color wp-block-paragraph">Stosuj rano na oczyszczoną skórę, przed kremem nawilżającym i ochroną SPF. Świetnie sprawdza się jako baza pod makijaż i element pielęgnacji antyoksydacyjnej.</p>
<!-- /wp:paragraph -->

<!-- wp:buttons -->
<div class="wp-block-buttons">
<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/kontakt/">Zapytaj o produkt</a></div>
<!-- /wp:button -->

<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/produkty/">Wróć do produktów</a></div>
<!-- /wp:button -->
</div>
<!-- /wp:buttons -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->
]]></content:encoded>
