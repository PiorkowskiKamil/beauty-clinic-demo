	<item>
		<title>Produkty</title>
		<link>https://newskin.local/produkty/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Produkty</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained","contentSize":"75rem"}} -->
<div class="wp-block-group alignfull" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color wp-block-paragraph">W&nbsp;salonie znajdziesz starannie wybrane kosmetyki, na których pracujemy podczas zabiegów. Pomożemy dobrać pielęgnację domową, która podtrzyma efekty wizyt.</p>
<!-- /wp:paragraph -->

<!-- wp:image {"sizeSlug":"full","linkDestination":"none","align":"wide","className":"bc-rounded"} -->
<figure class="wp-block-image alignwide size-full bc-rounded"><img src="/wp-content/themes/newskin-clinic/assets/images/produkty.jpg" alt="Kosmetyki dostępne w salonie NEW SKIN clinic"></figure>
<!-- /wp:image -->

<!-- wp:spacer {"height":"2.5rem"} -->
<div style="height:2.5rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","className":"bc-product-grid"} -->
<div class="wp-block-columns alignwide bc-product-grid">
<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:group {"style":{"spacing":{"padding":{"top":"1.5rem","right":"1.5rem","bottom":"2rem","left":"1.5rem"}}},"className":"bc-card","layout":{"type":"constrained"}} -->
<div class="wp-block-group bc-card" style="padding-top:1.5rem;padding-right:1.5rem;padding-bottom:2rem;padding-left:1.5rem">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none"} -->
<figure class="wp-block-image size-full"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-1.jpg" alt="Serum rewitalizujące z witaminą C"></figure>
<!-- /wp:image -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-large-font-size">Serum rewitalizujące z&nbsp;witaminą C</h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Rozświetla, wyrównuje koloryt i&nbsp;wspiera produkcję kolagenu. Idealne na dzień, pod krem z&nbsp;filtrem.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">149 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-product-more"} -->
<p class="bc-product-more wp-block-paragraph"><a href="/produkt-serum-witamina-c/">Dowiedz się więcej →</a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->
</div>
<!-- /wp:column -->

<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:group {"style":{"spacing":{"padding":{"top":"1.5rem","right":"1.5rem","bottom":"2rem","left":"1.5rem"}}},"className":"bc-card","layout":{"type":"constrained"}} -->
<div class="wp-block-group bc-card" style="padding-top:1.5rem;padding-right:1.5rem;padding-bottom:2rem;padding-left:1.5rem">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none"} -->
<figure class="wp-block-image size-full"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-2.jpg" alt="Krem odżywczy na noc"></figure>
<!-- /wp:image -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-large-font-size">Krem odżywczy na noc</h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Bogata formuła z&nbsp;ceramidami regeneruje barierę hydrolipidową podczas snu. Dla skóry suchej i&nbsp;zmęczonej.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">129 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-product-more"} -->
<p class="bc-product-more wp-block-paragraph"><a href="/produkt-krem-na-noc/">Dowiedz się więcej →</a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->
</div>
<!-- /wp:column -->

<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:group {"style":{"spacing":{"padding":{"top":"1.5rem","right":"1.5rem","bottom":"2rem","left":"1.5rem"}}},"className":"bc-card","layout":{"type":"constrained"}} -->
<div class="wp-block-group bc-card" style="padding-top:1.5rem;padding-right:1.5rem;padding-bottom:2rem;padding-left:1.5rem">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none"} -->
<figure class="wp-block-image size-full"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-3.jpg" alt="Olejek różany do twarzy"></figure>
<!-- /wp:image -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-large-font-size">Olejek różany do twarzy</h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Naturalny olejek z&nbsp;dzikiej róży, który koi, wygładza i&nbsp;przywraca skórze zdrowy blask. Kilka kropli wystarczy.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">99 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-product-more"} -->
<p class="bc-product-more wp-block-paragraph"><a href="/produkt-olejek-rozany/">Dowiedz się więcej →</a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"2rem"} -->
<div style="height:2rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color has-small-font-size wp-block-paragraph">Produkty kupisz stacjonarnie w&nbsp;salonie. Zapytaj o&nbsp;nie podczas wizyty. Ceny mogą ulec zmianie.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->
]]></content:encoded>
