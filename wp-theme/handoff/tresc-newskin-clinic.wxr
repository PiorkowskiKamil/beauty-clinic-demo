	<item>
		<title>Oferta</title>
		<link>https://newskin.local/oferta/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Oferta</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained","contentSize":"75rem"}} -->
<div class="wp-block-group alignfull" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color wp-block-paragraph">Każdy zabieg poprzedza krótka konsultacja. Nie wiesz, co wybrać? Zadzwoń, a&nbsp;doradzimy.</p>
<!-- /wp:paragraph -->

<!-- wp:spacer {"height":"2rem"} -->
<div style="height:2rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","verticalAlignment":"center","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"3rem"}}}} -->
<div class="wp-block-columns alignwide are-vertically-aligned-center">
<!-- wp:column {"verticalAlignment":"center","width":"38%"} -->
<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:38%">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded"} -->
<figure class="wp-block-image size-full bc-rounded"><img src="/wp-content/themes/newskin-clinic/assets/images/zabieg-twarz.jpg" alt="Zabieg pielęgnacyjny na twarz"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Twarz</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 id="pielegnacja-twarzy" class="has-text-align-center wp-block-heading">Pielęgnacja twarzy</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:paragraph {"className":"bc-offer-desc"} -->
<p class="bc-offer-desc wp-block-paragraph">Twarz to wizytówka, dlatego każdą pielęgnację zaczynamy od rozmowy i analizy potrzeb skóry. Znajdziesz tu głębokie oczyszczanie wodorowe, peelingi chemiczne dobrane do kondycji cery, mikrodermabrazję oraz ekspresowe zabiegi bankietowe na ważne okazje. Pracujemy na sprawdzonych preparatach, dbając o komfort i bezpieczeństwo na każdym etapie. Celem jest zdrowa, wypoczęta i rozświetlona skóra — bez pośpiechu i bez kompromisów.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-offer-price-note"} -->
<p class="bc-offer-price-note wp-block-paragraph"><a href="/cennik/">Zabiegi od <strong>150 zł</strong> · <span class="bc-cennik-cta">pełny cennik</span></a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"4rem"} -->
<div style="height:4rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","verticalAlignment":"center","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"3rem"}}}} -->
<div class="wp-block-columns alignwide are-vertically-aligned-center">
<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Relaks</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 id="masaze-i-rytualy-spa" class="has-text-align-center wp-block-heading">Masaże i&nbsp;rytuały SPA</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:paragraph {"className":"bc-offer-desc"} -->
<p class="bc-offer-desc wp-block-paragraph">To strefa, w której czas zwalnia. Proponujemy masaż relaksacyjny pleców na szybki reset, masaż całego ciała, masaż gorącymi kamieniami oraz autorskie rytuały SPA łączące peeling, masaż i maskę. Dobieramy techniki i intensywność do Twojego napięcia i samopoczucia. Wychodzisz lżejsza, rozluźniona i naprawdę wypoczęta.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-offer-price-note"} -->
<p class="bc-offer-price-note wp-block-paragraph"><a href="/cennik/">Zabiegi od <strong>120 zł</strong> · <span class="bc-cennik-cta">pełny cennik</span></a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center","width":"38%"} -->
<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:38%">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded"} -->
<figure class="wp-block-image size-full bc-rounded"><img src="/wp-content/themes/newskin-clinic/assets/images/zabieg-masaz.jpg" alt="Masaż gorącymi kamieniami"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"4rem"} -->
<div style="height:4rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","verticalAlignment":"center","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"3rem"}}}} -->
<div class="wp-block-columns alignwide are-vertically-aligned-center">
<!-- wp:column {"verticalAlignment":"center","width":"38%"} -->
<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:38%">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded"} -->
<figure class="wp-block-image size-full bc-rounded"><img src="/wp-content/themes/newskin-clinic/assets/images/zabieg-manicure.jpg" alt="Manicure w salonie"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Dłonie i&nbsp;stopy</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 id="manicure-i-pedicure" class="has-text-align-center wp-block-heading">Manicure i&nbsp;pedicure</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:paragraph {"className":"bc-offer-desc"} -->
<p class="bc-offer-desc wp-block-paragraph">Dłonie i stopy mówią o nas tyle, co twarz — tutaj zyskują pełną opiekę. Oferujemy manicure hybrydowy o trwałym kolorze, delikatny manicure klasyczny, odżywczy manicure japoński oraz kompleksowy pedicure podologiczny. Każdy zabieg wykonujemy sterylnie, z dbałością o zdrowie i naturalny wygląd płytki. Wyjdziesz z poczuciem, że naprawdę o siebie zadbałaś.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-offer-price-note"} -->
<p class="bc-offer-price-note wp-block-paragraph"><a href="/cennik/">Zabiegi od <strong>80 zł</strong> · <span class="bc-cennik-cta">pełny cennik</span></a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"4rem"} -->
<div style="height:4rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","verticalAlignment":"center","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"3rem"}}}} -->
<div class="wp-block-columns alignwide are-vertically-aligned-center">
<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Ciało</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 id="modelowanie-sylwetki" class="has-text-align-center wp-block-heading">Modelowanie sylwetki</h2>
<!-- /wp:heading -->

<!-- wp:separator {"className":"bc-gold-rule"} -->
<hr class="wp-block-separator has-alpha-channel-opacity bc-gold-rule">
<!-- /wp:separator -->

<!-- wp:paragraph {"className":"bc-offer-desc"} -->
<p class="bc-offer-desc wp-block-paragraph">Wspieramy jędrność skóry i smuklejszą sylwetkę nowoczesnymi, nieinwazyjnymi metodami. W ofercie są endermomasaż drenujący, fale radiowe RF zagęszczające skórę oraz aktywne zabiegi ujędrniające z masażem. Najlepsze efekty osiąga się serią, dlatego ułożymy plan dopasowany do Twoich celów. Pracujemy spokojnie, konsekwentnie i z troską o Twój komfort.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"bc-offer-price-note"} -->
<p class="bc-offer-price-note wp-block-paragraph"><a href="/cennik/">Zabiegi od <strong>180 zł</strong> · <span class="bc-cennik-cta">pełny cennik</span></a></p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center","width":"38%"} -->
<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:38%">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded"} -->
<figure class="wp-block-image size-full bc-rounded"><img src="/wp-content/themes/newskin-clinic/assets/images/zabieg-pielegnacja.jpg" alt="Naturalne maski pielęgnacyjne"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->

<!-- wp:spacer {"height":"3rem"} -->
<div style="height:3rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color has-small-font-size wp-block-paragraph">Pełne zestawienie cen i&nbsp;pakietów znajdziesz w&nbsp;<a href="/cennik/">cenniku</a>.</p>
<!-- /wp:paragraph -->

<!-- wp:buttons {"layout":{"type":"flex","justifyContent":"center"}} -->
<div class="wp-block-buttons">
<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/kontakt/">Umów wizytę</a></div>
<!-- /wp:button -->
</div>
<!-- /wp:buttons -->
</div>
<!-- /wp:group -->
]]></content:encoded>
		<excerpt:encoded><![CDATA[]]></excerpt:encoded>
