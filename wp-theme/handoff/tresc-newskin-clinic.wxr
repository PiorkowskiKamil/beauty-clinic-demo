	<item>
		<title>Olejek różany</title>
		<link>https://newskin.local/produkt-olejek-rozany/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">Olejek różany do twarzy</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:columns {"align":"wide"} -->
<div class="wp-block-columns alignwide">
<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded bc-product-photo"} -->
<figure class="wp-block-image size-full bc-rounded bc-product-photo"><img src="/wp-content/themes/newskin-clinic/assets/images/produkt-3.jpg" alt="Olejek różany do twarzy"></figure>
<!-- /wp:image -->
</div>
<!-- /wp:column -->

<!-- wp:column {"verticalAlignment":"center"} -->
<div class="wp-block-column is-vertically-aligned-center">
<!-- wp:paragraph {"className":"bc-card-icon"} -->
<p class="bc-card-icon wp-block-paragraph">99 zł</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p class="wp-block-paragraph">Naturalny olejek z dzikiej róży, który koi, wygładza i przywraca skórze elastyczność. Bogaty w kwasy tłuszczowe, odżywia i pomaga ujednolicić koloryt — wystarczy kilka kropli.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color wp-block-paragraph">Wmasuj wieczorem w skórę twarzy lub dodaj kilka kropli do kremu na noc. Sprawdza się także w pielęgnacji skóry suchej i wymagającej regeneracji.</p>
<!-- /wp:paragraph -->

<!-- wp:buttons -->
<div class="wp-block-buttons">
<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/kontakt/">Zapytaj o produkt</a></div>
<!-- /wp:button -->

<!-- wp:button -->
<div class="wp-block-button"><a class="wp-block-button__link wp-element-button" href="/produkty/">Wróć do produktów</a></div>
<!-- /wp:button -->
</div>
<!-- /wp:buttons -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->
]]></content:encoded>
