	<wp:author><wp:author_id>1</wp:author_id><wp:author_login><![CDATA[admin]]></wp:author_login><wp:author_email><![CDATA[admin@newskin.local]]></wp:author_email><wp:author_display_name><![CDATA[admin]]></wp:author_display_name></wp:author>
	<item>
		<title>O nas</title>
		<link>https://newskin.local/o-nas/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[
<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|50"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--50)">
<!-- wp:heading {"textAlign":"center","level":1} -->
<h1 class="wp-block-heading has-text-align-center wp-block-post-title">O&nbsp;nas</h1>
<!-- /wp:heading -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","style":{"spacing":{"padding":{"top":"var:preset|spacing|50","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignfull" style="padding-top:var(--wp--preset--spacing--50);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Nasza misja</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 class="wp-block-heading has-text-align-center">Piękno to zdrowa, zadbana skóra</h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"textAlign":"center"} -->
<p class="has-text-align-center wp-block-paragraph">NEW SKIN clinic powstało z&nbsp;przekonania, że dobra pielęgnacja nie potrzebuje wielkich obietnic, tylko wiedzy, uważności i&nbsp;czasu. Nie obiecujemy metamorfoz w&nbsp;godzinę. Obiecujemy rzetelną diagnozę, plan pielęgnacji dopasowany do Ciebie i&nbsp;zabiegi wykonywane spokojnie, starannie i&nbsp;z troską.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted","textAlign":"center"} -->
<p class="has-text-align-center has-muted-color has-text-color wp-block-paragraph">Od pierwszej wizyty prowadzimy kartę pielęgnacji, dzięki której każdy kolejny zabieg buduje efekt poprzedniego.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","backgroundColor":"cream","style":{"spacing":{"padding":{"top":"var:preset|spacing|60","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained","contentSize":"75rem"}} -->
<div class="wp-block-group alignfull has-cream-background-color has-background" style="padding-top:var(--wp--preset--spacing--60);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Wartości</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 class="wp-block-heading has-text-align-center">Pięć zasad, których się trzymamy</h2>
<!-- /wp:heading -->

<!-- wp:spacer {"height":"1.5rem"} -->
<div style="height:1.5rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:group {"layout":{"type":"constrained","contentSize":"50rem"}} -->
<div class="wp-block-group">
<!-- wp:details {"className":"bc-zasada bc-zasada--shield","summary":"Bezpieczeństwo przede wszystkim"} -->
<details class="wp-block-details bc-zasada bc-zasada--shield"><summary>Bezpieczeństwo przede wszystkim</summary>
<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Wywiad, diagnoza i&nbsp;dobór zabiegu zawsze poprzedzają pielęgnację. Jeśli zabieg nie jest dla Ciebie, powiemy to wprost.</p>
<!-- /wp:paragraph -->
</details>
<!-- /wp:details -->

<!-- wp:details {"className":"bc-zasada bc-zasada--plan","summary":"Indywidualny plan pielęgnacji"} -->
<details class="wp-block-details bc-zasada bc-zasada--plan"><summary>Indywidualny plan pielęgnacji</summary>
<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Nie ma dwóch takich samych skór. Plan zabiegów układamy pod Twoje potrzeby, tryb życia i&nbsp;budżet.</p>
<!-- /wp:paragraph -->
</details>
<!-- /wp:details -->

<!-- wp:details {"className":"bc-zasada bc-zasada--leaf","summary":"Naturalne efekty"} -->
<details class="wp-block-details bc-zasada bc-zasada--leaf"><summary>Naturalne efekty</summary>
<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Podkreślamy to, co w&nbsp;Tobie najlepsze, bez sztucznych, przerysowanych rezultatów.</p>
<!-- /wp:paragraph -->
</details>
<!-- /wp:details -->

<!-- wp:details {"className":"bc-zasada bc-zasada--award","summary":"Certyfikowane produkty i&nbsp;sprzęt"} -->
<details class="wp-block-details bc-zasada bc-zasada--award"><summary>Certyfikowane produkty i&nbsp;sprzęt</summary>
<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Pracujemy wyłącznie na dermokosmetykach o&nbsp;udokumentowanym działaniu i&nbsp;na atestowanych urządzeniach.</p>
<!-- /wp:paragraph -->
</details>
<!-- /wp:details -->

<!-- wp:details {"className":"bc-zasada bc-zasada--rozwoj","summary":"Ciągły rozwój"} -->
<details class="wp-block-details bc-zasada bc-zasada--rozwoj"><summary>Ciągły rozwój</summary>
<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Regularne szkolenia i&nbsp;kursy to u&nbsp;nas standard, bo kosmetologia idzie do przodu, a&nbsp;my razem z&nbsp;nią.</p>
<!-- /wp:paragraph -->
</details>
<!-- /wp:details -->
</div>
<!-- /wp:group -->
</div>
<!-- /wp:group -->

<!-- wp:group {"align":"full","style":{"spacing":{"padding":{"top":"var:preset|spacing|60","bottom":"var:preset|spacing|60"}}},"layout":{"type":"constrained","contentSize":"75rem"}} -->
<div class="wp-block-group alignfull" style="padding-top:var(--wp--preset--spacing--60);padding-bottom:var(--wp--preset--spacing--60)">
<!-- wp:paragraph {"textAlign":"center","className":"bc-eyebrow"} -->
<p class="has-text-align-center bc-eyebrow wp-block-paragraph">Zespół</p>
<!-- /wp:paragraph -->

<!-- wp:heading {"textAlign":"center"} -->
<h2 class="wp-block-heading has-text-align-center">Poznaj nasze specjalistki</h2>
<!-- /wp:heading -->

<!-- wp:spacer {"height":"1.5rem"} -->
<div style="height:1.5rem" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","style":{"spacing":{"blockGap":{"top":"1.5rem","left":"3rem"}}}} -->
<div class="wp-block-columns alignwide">
<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded bc-portrait"} -->
<figure class="wp-block-image size-full bc-rounded bc-portrait"><img src="/wp-content/themes/newskin-clinic/assets/images/zespol-1.jpg" alt="Marta Kowalska, kosmetolog i założycielka NEW SKIN clinic"></figure>
<!-- /wp:image -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-x-large-font-size">Marta Kowalska</h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"className":"bc-eyebrow"} -->
<p class="bc-eyebrow wp-block-paragraph">Kosmetolog, założycielka</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Magister kosmetologii z&nbsp;12-letnim doświadczeniem. Specjalizuje się w&nbsp;pielęgnacji przeciwstarzeniowej i&nbsp;terapiach skór problematycznych. Wierzy, że dobry zabieg zaczyna się od rozmowy.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->

<!-- wp:column -->
<div class="wp-block-column">
<!-- wp:image {"sizeSlug":"full","linkDestination":"none","className":"bc-rounded bc-portrait"} -->
<figure class="wp-block-image size-full bc-rounded bc-portrait"><img src="/wp-content/themes/newskin-clinic/assets/images/zespol-2.jpg" alt="Joanna Nowak, kosmetolog i specjalistka SPA"></figure>
<!-- /wp:image -->

<!-- wp:heading {"level":3} -->
<h3 class="wp-block-heading has-x-large-font-size">Joanna Nowak</h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"className":"bc-eyebrow"} -->
<p class="bc-eyebrow wp-block-paragraph">Kosmetolog, specjalistka SPA</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"textColor":"muted"} -->
<p class="has-muted-color has-text-color has-small-font-size wp-block-paragraph">Mistrzyni masażu i&nbsp;rytuałów SPA. Łączy techniki relaksacyjne z&nbsp;pielęgnacją ciała, dbając o&nbsp;to, żeby każda wizyta była też chwilą prawdziwego odpoczynku.</p>
<!-- /wp:paragraph -->
</div>
<!-- /wp:column -->
</div>
<!-- /wp:columns -->
</div>
<!-- /wp:group -->
]]></content:encoded>
		<excerpt:encoded><![CDATA[]]></excerpt:encoded>
